# =============================================================================
# PEDV — Sistema Jurídico
# Variáveis de ambiente necessárias para o deploy
#
# INSTRUÇÃO: copie este arquivo para .env.local (desenvolvimento)
#            ou configure como variáveis de ambiente na plataforma de deploy.
#
# NUNCA comite o .env.local no Git.
# =============================================================================


# ─── Supabase (OBRIGATÓRIO) ────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Settings → API

# URL do projeto Supabase (começa com https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave pública anônima (pode ser exposta no frontend — sem risco)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de service role (NUNCA exponha no frontend — apenas server-side)
# Necessária para operações administrativas (criar usuários, etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ─── URL da Aplicação (OBRIGATÓRIO em produção) ────────────────────────────────
# URL pública do sistema. Usado em:
#  - Links de e-mail (reset de senha, convites)
#  - Callbacks OAuth
#
# Desenvolvimento: http://localhost:3000
# Produção:        https://app.seuescritorio.com.br
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── OpenAI (OBRIGATÓRIO se usar IA Jurídica) ──────────────────────────────────
# Encontre em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Modelo a usar (padrão: gpt-4o-mini para custo-benefício)
# Opções: gpt-4o, gpt-4o-mini, gpt-4-turbo
OPENAI_MODEL=gpt-4o-mini

# URL base alternativa (opcional — para Azure OpenAI ou proxies)
# OPENAI_BASE_URL=https://api.openai.com/v1


# ─── Google Gmail OAuth — Aurora / Integrações (opcional) ─────────────────────
# Escopo inicial: gmail.readonly. Não configure variáveis NEXT_PUBLIC_ para secrets.
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# Deve apontar para a rota de callback cadastrada no Google Cloud Console.
# Desenvolvimento: http://localhost:3000/api/integracoes/google/oauth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integracoes/google/oauth/callback

# Segredos longos/aleatórios para assinar state e criptografar tokens.
# Use, por exemplo: openssl rand -base64 32
GOOGLE_OAUTH_STATE_SECRET=troque_por_um_segredo_longo
GOOGLE_TOKEN_ENCRYPTION_KEY=troque_por_um_segredo_longo


# ─── Segredo para Cron Jobs (OBRIGATÓRIO se usar monitoramento automático) ─────
# Segredo para autenticar chamadas externas ao /api/monitoramento/buscar
# Use um gerador de tokens aleatórios: openssl rand -hex 32
# ATENÇÃO: NUNCA use NEXT_PUBLIC_ nessa variável — ficaria exposto no browser
CRON_SECRET=seu_segredo_aleatorio_aqui_minimo_32_caracteres


# ─── Variáveis automáticas da Vercel (não configure manualmente) ───────────────
# A Vercel define VERCEL_URL automaticamente em cada deploy.
# O sistema usa ela como fallback para NEXT_PUBLIC_APP_URL.
# VERCEL_URL=seu-projeto.vercel.app  # ← não configure, a Vercel preenche
